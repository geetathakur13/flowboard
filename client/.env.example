# ===========================================
# FlowBoard Client Environment Variables
# ===========================================
# Copy to .env.local for dev. Prefix MUST be VITE_.

# Backend API URL
#   Dev:  http://localhost:5000/api
#   Prod: https://your-service.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Socket.io URL (usually the same host as API, without /api)
#   Dev:  http://localhost:5000
#   Prod: https://your-service.onrender.com
VITE_SOCKET_URL=http://localhost:5000
