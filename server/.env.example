# ===========================================
# FlowBoard Server Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# DO NOT commit .env to version control

# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database ---
# Get from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/flowboard?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/flowboard?retryWrites=true&w=majority

# --- JWT ---
# Use long random strings (min 32 chars). Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Anthropic Claude API ---
# Get from https://console.anthropic.com
# If missing, AI features will return mock responses instead of crashing
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (for OTP verification & password reset) ---
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
# For dev, you can use Ethereal: https://ethereal.email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="FlowBoard <no-reply@flowboard.app>"

# --- CORS ---
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
COOKIE_DOMAIN=
COOKIE_SECURE=false
